# ---- server ----
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
PUBLIC_BASE_URL=http://localhost:8080

# ---- backend selection (auto picks by platform) ----
# STT_BACKEND=auto        # auto | mlx_whisper | faster_whisper
# LLM_BACKEND=auto        # auto | ollama | openai_compat
# TTS_BACKEND=auto        # auto | kokoro

# ---- STT ----
STT_MODEL_MAC=mlx-community/distil-whisper-large-v3
STT_MODEL_CUDA=distil-whisper/distil-large-v3
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=en

# ---- LLM (Ollama on mac, vLLM/OpenAI-compat in prod) ----
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
# Use a non-thinking instruct model for low latency. For qwen3:8b set
# LLM_MODEL=qwen3:8b and LLM_SYSTEM_PREFIX="/no_think " (thinking adds latency).
LLM_MODEL=llama3:latest
LLM_SYSTEM_PREFIX=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512

# ---- TTS (Kokoro-ONNX) ----
TTS_MODEL_PATH=models/kokoro-v1.0.onnx
TTS_VOICES_PATH=models/voices-v1.0.bin
TTS_SAMPLE_RATE=24000
TTS_DEFAULT_VOICE=af_heart

# ---- VAD turn detection (mirrors OpenAI server_vad) ----
VAD_THRESHOLD=0.7
VAD_PREFIX_PADDING_MS=300
VAD_SILENCE_DURATION_MS=800

# ---- sessions ----
EPHEMERAL_TOKEN_TTL_S=600
MAX_CONCURRENT_SESSIONS=16
